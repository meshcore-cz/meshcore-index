{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meshcore-atlas/schema/firmware.schema.json",
  "title": "Firmware",
  "description": "A MeshCore firmware. The id comes from the directory name, not this file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "type", "maintainer", "description", "status"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "type": { "enum": ["official", "fork", "custom"] },
    "maintainer": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "maintenance", "inactive", "experimental"] },
    "repository": { "type": "string" },
    "website": { "type": "string" },
    "license": { "type": "string" },
    "latest_version": { "type": "string" },
    "released": { "type": "string" },
    "roles": { "type": "array", "items": { "type": "string" } },
    "features": { "type": "array", "items": { "type": "string" } },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "status": { "enum": ["supported", "partial", "untested", "unsupported"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
